# ─── ShopEase Java Backend — Configuration Template ─────────────────────────
#
# Copy this file to application.yml and fill in your real values.
# application.yml is gitignored — never commit secrets.
#
# Required environment variables (no defaults — must be set):
#   DB_PASSWORD   — PostgreSQL password
#   JWT_SECRET    — HS256 signing secret (min 32 hex chars)
#
# Optional overrides (defaults shown below):
#   DB_URL        — JDBC URL          (default: localhost:9508/shopease)
#   DB_USERNAME   — DB user           (default: postgres)
#   SERVER_PORT   — HTTP port         (default: 8085)
# ─────────────────────────────────────────────────────────────────────────────

spring:
  application:
    name: backend-java
  datasource:
    url: ${DB_URL:jdbc:postgresql://localhost:9508/shopease}
    username: ${DB_USERNAME:postgres}
    password: ${DB_PASSWORD}          # REQUIRED — set in env / IDE run config
    driver-class-name: org.postgresql.Driver
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: false
    properties:
      hibernate:
        format_sql: false

server:
  port: ${SERVER_PORT:8085}
  servlet:
    context-path: /api

jwt:
  secret: ${JWT_SECRET}              # REQUIRED — set in env / IDE run config
  expiration: 86400000               # 24 hours in milliseconds
